{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Samik081/mcp-adguard-home",
  "version": "0.5.8",
  "title": "AdGuard Home MCP Server",
  "description": "Manage AdGuard Home through AI assistants",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/Samik081/mcp-adguard-home",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@samik081/mcp-adguard-home",
      "version": "0.5.8",
      "runtimeHint": "node",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ADGUARD_URL",
          "description": "URL of the AdGuard Home instance (e.g. http://192.168.1.1:3000)",
          "isRequired": true
        },
        {
          "name": "ADGUARD_USERNAME",
          "description": "AdGuard Home username",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "ADGUARD_PASSWORD",
          "description": "AdGuard Home password",
          "isRequired": true,
          "isSecret": true
        }
      ]
    },
    {
      "registryType": "oci",
      "identifier": "ghcr.io/samik081/mcp-adguard-home:0.5.8",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ADGUARD_URL",
          "description": "URL of the AdGuard Home instance (e.g. http://192.168.1.1:3000)",
          "isRequired": true
        },
        {
          "name": "ADGUARD_USERNAME",
          "description": "AdGuard Home username",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "ADGUARD_PASSWORD",
          "description": "AdGuard Home password",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
